# Rede Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Helius — SERVIDOR APENAS (sem NEXT_PUBLIC_)
HELIUS_API_KEY=sua_api_key_aqui

# Pinata — SERVIDOR APENAS (sem NEXT_PUBLIC_)
PINATA_JWT=seu_jwt_aqui

# Likes pagos
# Preço do like em SOL (fixo, ajustar manualmente conforme cotação)
# Pagamento vai 100% para o artista que mintou a obra
NEXT_PUBLIC_LIKE_PRICE_SOL=0.0003

# Coletar (mint de uma edição da obra na carteira de quem coleta)
# Preço em SOL (fixo), pago 100% ao artista original, além da taxa de gás do mint.
# Nas primeiras 24h após o registro, coleta pelo preço base. Depois disso, só
# dá pra coletar via lance (5x/10x/20x/50x desse preço — ver lib/collectPayment.js).
NEXT_PUBLIC_COLLECT_PRICE_SOL=0.0012

# Mercado de revenda — SERVIDOR APENAS (sem NEXT_PUBLIC_)
# Keypair Solana da vault custodial que guarda o NFT enquanto está anunciado
# pra venda (ver lib/vaultSigner.js). Formato: secretKey de 64 bytes em
# base58 — o mesmo exportado por `solana-keygen new -o vault.json` (converta
# o array JSON pra base58) ou pela opção "Exportar chave privada" do Phantom
# numa carteira NOVA e dedicada (nunca reuse uma carteira pessoal aqui).
# Essa carteira também precisa de um pouco de SOL pra pagar o gás das
# transferências que faz em nome dos usuários.
MARKETPLACE_VAULT_SECRET_KEY=
