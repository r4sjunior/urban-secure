# Rede Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Helius — SERVIDOR APENAS (sem NEXT_PUBLIC_)
HELIUS_API_KEY=sua_api_key_aqui

# Pinata — SERVIDOR APENAS (sem NEXT_PUBLIC_)
PINATA_JWT=seu_jwt_aqui

# Likes pagos
# Preço do like em SOL (fixo, ajustar manualmente conforme cotação)
NEXT_PUBLIC_LIKE_PRICE_SOL=0.0003

# Wallet que recebe a taxa da Urban Secure (20% do like)
# Definir as DUAS — pública para o client montar a tx, privada para o
# servidor validar o pagamento em /api/likes
NEXT_PUBLIC_URBAN_FEE_WALLET=endereco_da_wallet_da_plataforma
URBAN_FEE_WALLET=endereco_da_wallet_da_plataforma
