# Rede Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Helius — SERVIDOR APENAS (sem NEXT_PUBLIC_)
HELIUS_API_KEY=sua_api_key_aqui

# Pinata — SERVIDOR APENAS (sem NEXT_PUBLIC_)
PINATA_JWT=seu_jwt_aqui

# Likes pagos
# Preço do like em SOL (fixo, ajustar manualmente conforme cotação)
# Pagamento vai 100% para o artista que mintou a obra
NEXT_PUBLIC_LIKE_PRICE_SOL=0.0003

# Coletar (mint de uma edição da obra na carteira de quem coleta)
# Preço em SOL (fixo), pago 100% ao artista original, além da taxa de gás do mint.
# Só funciona nas primeiras 24h após o registro da obra.
NEXT_PUBLIC_COLLECT_PRICE_SOL=0.0012
